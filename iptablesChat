# Cleaned rules for RIC SCTP (E2AP) + Docker bridges
*raw
:PREROUTING ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
# Bypass conntrack for SCTP verso backend E2Term (evita COOKIE-ECHO marcato INVALID)
-A PREROUTING -p sctp -d 192.168.49.2 --dport 32222 -j CT --notrack
COMMIT

*filter
:INPUT ACCEPT [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
:DOCKER - [0:0]
:DOCKER-BRIDGE - [0:0]
:DOCKER-CT - [0:0]
:DOCKER-FORWARD - [0:0]
:DOCKER-ISOLATION-STAGE-1 - [0:0]
:DOCKER-ISOLATION-STAGE-2 - [0:0]
:DOCKER-USER - [0:0]

# --- SCTP fast-path senza ctstate (prima di tutto)
-A FORWARD -p sctp -d 192.168.49.2 --dport 32222 -j ACCEPT
-A FORWARD -p sctp -s 192.168.49.2 --sport 32222 -j ACCEPT

# --- Flusso Docker standard (lasciato intatto)
-A FORWARD -j DOCKER-USER
-A FORWARD -j DOCKER-FORWARD
-A DOCKER-BRIDGE -o docker0 -j DOCKER
-A DOCKER-BRIDGE -o br-ae399d41b2eb -j DOCKER
-A DOCKER-CT -o docker0 -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
-A DOCKER-CT -o br-ae399d41b2eb -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
-A DOCKER-FORWARD -j DOCKER-CT
-A DOCKER-FORWARD -j DOCKER-ISOLATION-STAGE-1
-A DOCKER-FORWARD -j DOCKER-BRIDGE
-A DOCKER-FORWARD -i docker0 -j ACCEPT
-A DOCKER-FORWARD -i br-ae399d41b2eb -j ACCEPT
-A DOCKER-ISOLATION-STAGE-1 -i docker0 ! -o docker0 -j DOCKER-ISOLATION-STAGE-2
-A DOCKER-ISOLATION-STAGE-1 -i br-ae399d41b2eb ! -o br-ae399d41b2eb -j DOCKER-ISOLATION-STAGE-2
-A DOCKER-ISOLATION-STAGE-2 -o br-ae399d41b2eb -j DROP
-A DOCKER-ISOLATION-STAGE-2 -o docker0 -j DROP

# Facoltativo: consenti SCTP anche nella DOCKER-USER (non necessario con le due regole sopra)
#-A DOCKER-USER -p sctp -d 192.168.49.2 --dport 32222 -j ACCEPT
#-A DOCKER-USER -p sctp -s 192.168.49.2 --sport 32222 -j ACCEPT

COMMIT

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
:DOCKER - [0:0]

# DNAT verso backend E2Term (unica istanza per ciascun dst esterno)
-A PREROUTING -i ens18 -d 192.168.17.70 -p sctp --dport 32222 -j DNAT --to-destination 192.168.49.2:32222
-A PREROUTING -i ens18 -d 172.17.0.1  -p sctp --dport 32222 -j DNAT --to-destination 192.168.49.2:32222

# Docker PREROUTING locale
-A PREROUTING -m addrtype --dst-type LOCAL -j DOCKER

# Docker OUTPUT locale
-A OUTPUT ! -d 127.0.0.0/8 -m addrtype --dst-type LOCAL -j DOCKER

# MASQUERADE (deduplicate)
-A POSTROUTING -d 192.168.49.2 -p sctp --dport 32222 -j MASQUERADE
-A POSTROUTING -s 192.168.49.0/24 ! -o br-ae399d41b2eb -j MASQUERADE
-A POSTROUTING -s 172.17.0.0/16 ! -o docker0       -j MASQUERADE

# DNAT Docker già presenti (mantenuti senza duplicati)
-A DOCKER -i br-ae399d41b2eb -j RETURN
-A DOCKER -i docker0 -j RETURN
-A DOCKER ! -i docker0 -p tcp --dport 5000 -j DNAT --to-destination 172.17.0.2:5000
-A DOCKER -d 127.0.0.1 ! -i br-ae399d41b2eb -p tcp --dport 32773 -j DNAT --to-destination 192.168.49.2:22
-A DOCKER -d 127.0.0.1 ! -i br-ae399d41b2eb -p tcp --dport 32774 -j DNAT --to-destination 192.168.49.2:2376
-A DOCKER -d 127.0.0.1 ! -i br-ae399d41b2eb -p tcp --dport 32775 -j DNAT --to-destination 192.168.49.2:5000
-A DOCKER -d 127.0.0.1 ! -i br-ae399d41b2eb -p tcp --dport 32776 -j DNAT --to-destination 192.168.49.2:8443
-A DOCKER -d 127.0.0.1 ! -i br-ae399d41b2eb -p tcp --dport 32777 -j DNAT --to-destination 192.168.49.2:32443
-A DOCKER ! -i docker0 -p tcp --dport 8090 -j DNAT --to-destination 172.17.0.3:8080
COMMIT
